{
  "manifest_version": 3,
  "name": "EPP Viewer",
  "version": "1.4.0",
  "description": "View and print .epp (Easy Paper Package) documents — works with local files and URLs on the internet.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open EPP Viewer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "webNavigation",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "epp_redirect_ruleset",
      "enabled": true,
      "path": "epp-redirect-rules.json"
    }]
  },
  "content_scripts": [
    {
      "matches": ["file://*.epp", "file:///*.epp"],
      "js": ["epp-core.js", "content.js"],
      "css": ["epp-style.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "epp-core.js", "epp-style.css", "viewer.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
