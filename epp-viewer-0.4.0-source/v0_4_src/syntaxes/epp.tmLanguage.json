{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "EPP",
  "scopeName": "source.epp",
  "fileTypes": ["epp"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#version-marker" },
    { "include": "#newpage-command" },
    { "include": "#page-command" },
    { "include": "#label-command" },
    { "include": "#bare-command" },
    { "include": "#meta-command" },
    { "include": "#table-row-command" },
    { "include": "#callout-command" },
    { "include": "#watermark-command" },
    { "include": "#sign-command" },
    { "include": "#ex-command" },
    { "include": "#text-command" }
  ],
  "repository": {
    "comment": {
      "match": ";.*$",
      "name": "comment.line.semicolon.epp"
    },

    "version-marker": {
      "match": "^\\s*(%)(epp=[^%]*)(%)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.epp" },
        "2": { "name": "keyword.other.version.epp" },
        "3": { "name": "punctuation.definition.tag.epp" }
      }
    },

    "newpage-command": {
      "match": "(@)(newpage|space|line)\\b",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      }
    },

    "page-command": {
      "comment": "v0.3: @page <label> {color=,lined,rotate=}",
      "begin": "(@)(page)\\b\\s*([^\\s{;]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" },
        "3": { "name": "constant.other.page-label.epp" }
      },
      "end": "(\\})|(?=\\s*$)|(?=@)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "patterns": [
        { "include": "#page-attribute-block" }
      ]
    },

    "label-command": {
      "match": "(@)(label)\\b\\s*([^\\s{;]*)",
      "captures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" },
        "3": { "name": "entity.name.tag.label.epp" }
      }
    },

    "meta-command": {
      "begin": "(@)(meta)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      },
      "end": "(?=\\s|;|$)",
      "patterns": [
        {
          "match": "([A-Za-z_][\\w-]*)(=)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" }
          }
        },
        { "include": "#string" }
      ]
    },

    "table-row-command": {
      "begin": "(@)(table|row)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      },
      "end": "(?<=\")",
      "patterns": [
        { "include": "#pipe-string" }
      ]
    },

    "callout-command": {
      "comment": "v0.3: @callout \"text\" {color=}",
      "begin": "(@)(callout)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      },
      "end": "(\\})|(?=\\s*$)|(?=@)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#callout-attribute-block" }
      ]
    },

    "callout-attribute-block": {
      "comment": "v0.3: @callout's color= uses a different value set than @text/@heading's color=",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "name": "meta.attribute-block.epp",
      "patterns": [
        {
          "match": "\\b(color)\\s*(=)\\s*(yellow|green|blue|red|gray|grey|purple)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "support.constant.color.epp" }
          }
        },
        {
          "match": "([A-Za-z_][\\w-]*)\\s*(=)\\s*([^,}]*)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "string.unquoted.attribute-value.epp" }
          }
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.epp"
        }
      ]
    },

    "watermark-command": {
      "comment": "v0.4: @watermark \"text\" {color=,opacity=,rotate=,size=}",
      "begin": "(@)(watermark)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      },
      "end": "(\\})|(?=\\s*$)|(?=@)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#watermark-attribute-block" }
      ]
    },

    "watermark-attribute-block": {
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "name": "meta.attribute-block.epp",
      "patterns": [
        {
          "match": "\\b(color)\\s*(=)\\s*(black|red|blue|green|gray|grey|white|amber|orange|purple)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "support.constant.color.epp" }
          }
        },
        {
          "match": "\\b(opacity|rotate|size)\\s*(=)\\s*(\\d+)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "constant.numeric.epp" }
          }
        },
        {
          "match": "([A-Za-z_][\\w-]*)\\s*(=)\\s*([^,}]*)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "string.unquoted.attribute-value.epp" }
          }
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.epp"
        }
      ]
    },

    "sign-command": {
      "comment": "v0.4: @sign \"NAME\" {ORG-ID}  and  @signandclose \"NAME\" {ORG-ID} — the org id is a bare key inside the attribute block, not a color/flag, so it's highlighted as a constant rather than matched by the generic key=value rule",
      "begin": "(@)(sign|signandclose)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      },
      "end": "(\\})|(?=\\s*$)|(?=@)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#sign-attribute-block" }
      ]
    },

    "sign-attribute-block": {
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "name": "meta.attribute-block.epp",
      "patterns": [
        {
          "match": "[A-Za-z_][\\w-]*",
          "name": "constant.other.org-id.epp"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.epp"
        }
      ]
    },

    "ex-command": {
      "comment": "v0.4: @ex:anything \"text\" {attrs} — extension namespace, parsed but ignored by the renderer; highlighted distinctly to signal it has no defined rendering behavior",
      "begin": "(@)(ex:[\\w-]*)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.other.extension.epp" }
      },
      "end": "(\\})|(?=\\s*$)|(?=@)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#attribute-block" }
      ]
    },

    "bare-command": {
      "comment": "@header / @footer / @title / @quote — text only, no attrs",
      "begin": "(@)(header|footer|title|quote)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      },
      "end": "(?<=\")",
      "patterns": [
        { "include": "#string" }
      ]
    },

    "text-command": {
      "comment": "@heading / @text / @bullet / @code — text plus optional {attrs}",
      "begin": "(@)(heading|text|bullet|code)\\b\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.keyword.epp" },
        "2": { "name": "keyword.control.epp" }
      },
      "end": "(\\})|(?=\\s*$)|(?=@)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#attribute-block" }
      ]
    },

    "attribute-block": {
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "name": "meta.attribute-block.epp",
      "patterns": [
        {
          "match": "\\b(align)\\s*(=)\\s*(left|center|right)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "constant.language.epp" }
          }
        },
        {
          "match": "\\b(color)\\s*(=)\\s*(black|red|blue|green|gray|grey|white|amber|orange|purple)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "support.constant.color.epp" }
          }
        },
        {
          "comment": "v0.3: highlight= on @text / @heading",
          "match": "\\b(highlight)\\s*(=)\\s*(yellow|green|blue|pink|red|orange)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "support.constant.color.epp" }
          }
        },
        {
          "match": "\\b(type)\\s*(=)\\s*(disc|number|check|arrow|star)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "constant.language.epp" }
          }
        },
        {
          "match": "\\b(bold|italic|underline)\\b(?!\\s*=)",
          "name": "constant.language.boolean.epp"
        },
        {
          "match": "([A-Za-z_][\\w-]*)\\s*(=)\\s*([^,}]*)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "string.unquoted.attribute-value.epp" }
          }
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.epp"
        }
      ]
    },

    "page-attribute-block": {
      "comment": "v0.3: attribute block specific to @page — color=, lined, rotate=",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.attribute-block.epp" }
      },
      "name": "meta.attribute-block.epp",
      "patterns": [
        {
          "match": "\\b(color)\\s*(=)\\s*(cream|white|blue|pink|green|yellow|gray|grey)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "support.constant.color.epp" }
          }
        },
        {
          "match": "\\b(rotate)\\s*(=)\\s*(90|180|270)\\b",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "constant.numeric.epp" }
          }
        },
        {
          "match": "\\b(lined)\\b(?!\\s*=)",
          "name": "constant.language.boolean.epp"
        },
        {
          "match": "([A-Za-z_][\\w-]*)\\s*(=)\\s*([^,}]*)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.epp" },
            "2": { "name": "keyword.operator.epp" },
            "3": { "name": "string.unquoted.attribute-value.epp" }
          }
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.epp"
        }
      ]
    },

    "string": {
      "begin": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.epp" } },
      "end": "\"",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.epp" } },
      "name": "string.quoted.double.epp",
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-token" }
      ]
    },

    "pipe-string": {
      "comment": "Same as #string but additionally highlights the | cell separator",
      "begin": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.epp" } },
      "end": "\"",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.epp" } },
      "name": "string.quoted.double.epp",
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-token" },
        {
          "match": "\\|",
          "name": "punctuation.separator.pipe.epp"
        }
      ]
    },

    "string-escape": {
      "match": "\\\\[\"\\\\\\[\\]]",
      "name": "constant.character.escape.epp"
    },

    "string-token": {
      "match": "\\[(newline|page)\\]",
      "name": "constant.character.placeholder.epp"
    }
  }
}
